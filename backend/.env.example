# ===== 数据库 =====
DATABASE_URL=mysql+pymysql://root:your_password@localhost:3306/account
ASYNC_DATABASE_URL=mysql+aiomysql://root:your_password@localhost:3306/account

# ===== JWT =====
JWT_SECRET_KEY=change-me-to-a-random-secret-key
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=30
JWT_REFRESH_TOKEN_EXPIRE_DAYS=7

# ===== 服务 =====
APP_NAME=日常记账App
APP_VERSION=1.0.0
PORT=8000
DEBUG=true

# ===== CORS =====
CORS_ORIGINS=["http://localhost:5173","http://localhost:3000"]
